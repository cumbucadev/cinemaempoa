FROM python:3.14-slim

WORKDIR /app

RUN apt-get update
RUN apt-get install locales locales-all -y
RUN apt update && apt install tzdata -y

ENV TZ="America/Sao_Paulo"
ENV LC_ALL pt_BR.UTF-8
ENV LANG pt_BR.UTF-8
ENV LANGUAGE pt_BR.UTF-8

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

# venv lives outside /app so it survives the dev bind mount (docker-compose.dev.yml
# mounts the repo over /app, which would otherwise shadow a venv built at image time)
ENV UV_PROJECT_ENVIRONMENT=/opt/venv
ENV PATH="/opt/venv/bin:$PATH"

COPY pyproject.toml uv.lock .
RUN uv sync --frozen

# Install git for code editor integration
RUN apt-get install git -y

# Install sqlite3 for database debugging
RUN apt-get install sqlite3 -y

EXPOSE 5000

# Just do nothing
CMD ["tail", "-f", "/dev/null"]
